{
  "name": "@apo/sdk",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./otel": {
      "development": "./src/otel/index.ts",
      "types": "./dist/otel/index.d.ts",
      "default": "./dist/otel/index.js"
    },
    "./agent-task": {
      "development": "./src/agent-task/public.ts",
      "types": "./dist/agent-task/public.d.ts",
      "default": "./dist/agent-task/public.js"
    },
    "./agent-task/integrations/ai-sdk": {
      "development": "./src/agent-task/integrations/ai-sdk.ts",
      "types": "./dist/agent-task/integrations/ai-sdk.d.ts",
      "default": "./dist/agent-task/integrations/ai-sdk.js"
    },
    "./agent-task/integrations/openai": {
      "development": "./src/agent-task/integrations/openai.ts",
      "types": "./dist/agent-task/integrations/openai.d.ts",
      "default": "./dist/agent-task/integrations/openai.js"
    },
    "./agent-task/integrations/anthropic": {
      "development": "./src/agent-task/integrations/anthropic.ts",
      "types": "./dist/agent-task/integrations/anthropic.d.ts",
      "default": "./dist/agent-task/integrations/anthropic.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "build:agent-task-runtime": "node scripts/build-agent-task-runtime.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.21.5",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9",
    "zod": "^3.22.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "effect": "^3.19.12"
  }
}
