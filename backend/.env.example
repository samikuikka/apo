# Backend Environment Variables
# DATABASE_URL=sqlite:///./apo.db

# Agent-task LLM configuration (OpenRouter)
# These are passed through to agent-task subprocesses.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AGENT_TASK_OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# SPEC-124: self-hosted alpha topology.
# AUTH_SECRET must be set to a strong random value for any non-dev deploy.
# In dev, leaving it empty puts the backend in open-dev mode (auth bypassed).
# Generate one with: openssl rand -hex 32
# AUTH_SECRET=

# Set to "false" to disable the in-process scheduler. Schedules stay visible
# in the UI but will not dispatch. Alpha assumes one backend process owns this.
# SCHEDULER_ENABLED=true

# Backend and frontend URLs used for CORS, redirects, and the runtime-config
# descriptor surfaced on the system settings page.
# BACKEND_URL=http://127.0.0.1:8000
# FRONTEND_URL=http://localhost:3000

# Project Task Source — filesystem root for self-host/dev mode sources.
# Defaults to <repo>/.cache/task-sources if unset. Server-owned writable.
# In container deploys, point this at the persistent task_source_cache volume.
# TASK_SOURCE_CACHE_DIR=/var/lib/apo/task-sources

# SPEC-125 hardening: task-workspace dependency install policy.
# Real synced Git sources need their own node_modules/venv before
# runner.mjs can load task modules. The install runs lazily before each
# task run, cached by lockfile hash under <TASK_INSTALL_CACHE_DIR>.
#
# Set to "true"/"1" to skip installs entirely (escape hatch for air-gapped
# deploys where you pre-install dependencies into the image).
# TASK_INSTALL_DISABLE=false
#
# Per-install timeout. Default 180s. Clamped to minimum 30s.
# TASK_INSTALL_TIMEOUT_SECONDS=180
#
# Where install markers live. Defaults to <TASK_SOURCE_CACHE_DIR>/installs.
# Point this at a persistent volume in container deploys.
# TASK_INSTALL_CACHE_DIR=/var/lib/apo/task-installs

# Project Task Source — per-clone/fetch timeout in seconds (default 60).
# TASK_SOURCE_GIT_TIMEOUT_SECONDS=60

# GitHub OAuth (SPEC-121) — optional. When all four are set, projects
# get a "Connect GitHub" button on the task source form so private repos
# clone without per-user PATs. When any are missing, GitHub Connect is
# hidden and only the manual URL paste flow is available.
# Create the OAuth App at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:8000/v1/github/callback
# Generate the encryption key with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# GITHUB_CLIENT_ID=iv1...
# GITHUB_CLIENT_SECRET=...
# GITHUB_REDIRECT_URI=http://localhost:8000/v1/github/callback
# GITHUB_TOKEN_ENCRYPTION_KEY=
