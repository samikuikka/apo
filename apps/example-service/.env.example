# Example Service — environment variables
# Copy to .env and fill in. (.env is gitignored.)

# --- Required for the chat endpoint (/api/agent/chat) ---
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_REFERRER=http://localhost:3001
OPENROUTER_TITLE=apo Example

# --- Required for the agent-task e2e adapters (pnpm e2e) ---
# The Claude Agent SDK adapter (claude-adapter.ts) reads these via process.env
# passthrough — the SDK handles ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN /
# ANTHROPIC_BASE_URL natively. CLAUDE_MODEL optionally overrides the model.
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=your_zai_api_key
# Optional alternative name if your tooling expects the standard Anthropic env var
ANTHROPIC_API_KEY=
# Optional: override the model the Claude Agent SDK uses (defaults to SDK default)
CLAUDE_MODEL=
