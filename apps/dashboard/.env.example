NEXT_PUBLIC_APO_BACKEND_URL=http://localhost:8000
AUTH_SECRET=change-me-to-a-random-secret
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000
# Dev-only escape hatch. Keep this false unless you intentionally want the
# dashboard UI to skip page auth while testing in development.
NEXT_PUBLIC_AUTH_DISABLED=false
# Uncomment to auto-create first admin user on backend startup:
# INIT_USER_EMAIL=admin@example.com
# INIT_USER_PASSWORD=ChangeMe123
# INIT_USER_NAME=Admin
