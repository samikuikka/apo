	.deliverable__mark--pass {
		color: var(--sl-color-accent);
		font-weight: 700;
	}

	/* ══════════════════════════════════════════════════════════════════
	   DEBUGGABLE TRACES: a real call tree — parent calls with tokens/cost,
	   child calls indented under them, args/messages deeper still. Lines
	   draw in top-to-bottom on scroll, like the trace assembling.
	   ══════════════════════════════════════════════════════════════════ */
	.trace {
		margin-top: 0.5rem;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 0.66rem;
		line-height: 1.7;
		border-left: 1px solid var(--sl-color-gray-5);
		padding-left: 0.6rem;
	}

	.trace__line {
		color: var(--sl-color-gray-2);
		opacity: 0;
		transform: translateX(-6px);
		transition: opacity 0.35s ease, transform 0.35s ease;
		transition-delay: calc(var(--i, 0) * 200ms);
	}

	/* Parent calls (level 0): run refund, generate_reply. */
	.trace__line--0 {
		color: var(--sl-color-gray-1);
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
	}

	/* Child calls (level 1): indented, slightly dimmer. */
	.trace__line--1 {
		padding-left: 0.9rem;
		color: var(--sl-color-gray-3);
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
	}

	/* Args/messages (level 2): indented deeper, dimmest. */
	.trace__line--2,
	.trace__line--4 {
		padding-left: 1.8rem;
		color: var(--sl-color-gray-4);
		font-size: 0.6rem;
	}

	/* The third parent (generate_reply) — same as level 1. */
	.trace__line--3 {
		padding-left: 0.9rem;
		color: var(--sl-color-gray-3);
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
	}

	.trace__arrow {
		color: var(--sl-color-gray-5);
		flex-shrink: 0;
	}

	.trace__indent {
		color: var(--sl-color-gray-4);
	}

	/* Token/cost metadata — right-aligned, dim. */
	.trace__meta {
		margin-left: auto;
		color: var(--sl-color-gray-5);
		font-size: 0.55rem;
	}

	.bento[data-visible] .trace__line {
		opacity: 1;
		transform: translateX(0);
	}

	/* ══════════════════════════════════════════════════════════════════
	   TRACK REGRESSION: two bars fill in sequence, the second drops.
	   ══════════════════════════════════════════════════════════════════ */
	.regression {
		margin-top: auto;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 0.7rem;
	}

	.regression__bar {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		opacity: 0;
		transform: translateX(-4px);
		transition: opacity 0.35s ease, transform 0.35s ease;
		transition-delay: calc(var(--i, 0) * 400ms + 0.2s);
	}

	.bento[data-visible] .regression__bar {
		opacity: 1;
		transform: translateX(0);
	}

	.regression__label {
		color: var(--sl-color-gray-4);
		width: 2.5rem;
		flex-shrink: 0;
	}

	.regression__track {
		flex: 1;
		height: 0.5rem;
		background: var(--sl-color-gray-5);
		overflow: hidden;
	}

	.regression__fill {
		display: block;
		height: 100%;
		width: 0;
		background: var(--sl-color-accent);
		transition: width 0.7s cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: calc(var(--i, 0) * 400ms + 0.5s);
	}

	.bento[data-visible] .regression__fill {
		width: var(--w);
	}

	.regression__fill--down {
		background: oklch(0.7 0.16 25);
	}

	.regression__count {
		color: var(--sl-color-gray-2);
		width: 2.5rem;
		flex-shrink: 0;
		text-align: right;
	}

	/* ══════════════════════════════════════════════════════════════════
	   SCHEDULES AS POLICY: three subset/interval rows stack in.
	   ══════════════════════════════════════════════════════════════════ */
	.schedule {
		margin-top: auto;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 0.7rem;
	}

	.schedule__row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.5rem;
		padding: 0.25rem 0;
		border-bottom: 1px solid var(--sl-color-gray-6);
		opacity: 0;
		transform: translateY(-4px);
		transition: opacity 0.3s ease, transform 0.3s ease;
		transition-delay: calc(var(--i, 0) * 150ms + 0.2s);
	}

	.schedule__row:last-child {
		border-bottom: none;
	}

	.bento[data-visible] .schedule__row {
		opacity: 1;
		transform: translateY(0);
	}

	.schedule__tag {
		color: var(--sl-color-gray-2);
		border: 1px solid var(--sl-color-gray-5);
		padding: 0.05rem 0.4rem;
	}

	.schedule__cadence {
		color: var(--sl-color-gray-4);
	}

	/* ══════════════════════════════════════════════════════════════════
	   prefers-reduced-motion: freeze every animation to its final frame.
	   ══════════════════════════════════════════════════════════════════ */
	@media (prefers-reduced-motion: reduce) {
		.spec__pair,
		.trace__line,
		.regression__bar,
		.schedule__row {
			opacity: 1 !important;
			transform: none !important;
			transition: none !important;
			animation: none !important;
		}

		.converge__line {
			animation: none !important;
			stroke: var(--sl-color-accent) !important;
			opacity: 0.6 !important;
			filter: drop-shadow(0 0 2px oklch(0.72 0.19 145 / 0.4)) !important;
		}

		.deliverable__row {
			opacity: 1 !important;
			transform: none !important;
			transition: none !important;
		}

		.regression__fill {
			width: var(--w) !important;
			transition: none !important;
		}
	}
</style>

<script>
	// Trip all per-card animations when the section scrolls into view. The
	// [data-visible] attribute on the root is what each scoped keyframe keys off.
	// NOTE: the import must be INSIDE the script tag — frontmatter imports are
	// server-side only and don't reach the browser. Without this, onVisible is
	// undefined and the animations never fire.
	import { onVisible } from "./demos/demo-motion";

	const section = document.querySelector<HTMLElement>("[data-landing-features]");
	if (section) {
		onVisible(section, (state) => {
			section.toggleAttribute("data-visible", state === "visible");
		});
	}
</script>
