	/* The deliverable code — the structured output apo judges. */
	.deliverable__code {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 0.6rem;
		color: var(--sl-color-gray-2);
		flex: 1;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	/* Verdict marks: — for ignored chat, ✓ for the checked deliverable. */
	.deliverable__mark {
		flex-shrink: 0;
		font-size: 0.7rem;
		width: 1rem;
		text-align: center;
	}

	.deliverable__mark--ignore {
		color: var(--sl-color-gray-3);
