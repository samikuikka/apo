---
// Overrides Starlight's built-in TwoColumnContent to match Flue's layout:
// the right-side Table of Contents is hidden below 96rem (1536px) — the same
// `max-2xl:hidden` Flue uses — so the content column gets the full main width
// on small/medium desktop screens and centers further right, like Flue's.
//
// The TOC remains reachable: as a drawer on mobile, and as this sidebar on
// ultrawide (≥1536px) displays. Everything else is Starlight's default.
---
<div class="lg:sl-flex">
	{
		Astro.locals.starlightRoute.toc && (
			<aside class="right-sidebar-container print:hidden">
				<div class="right-sidebar">
					<slot name="right-sidebar" />
				</div>
			</aside>
		)
	}
	<div class="main-pane"><slot /></div>
</div>

<style>
	@layer starlight.core {
		.main-pane {
			isolation: isolate;
			/* With the TOC hidden below 96rem, the main pane takes the full
			   available width so the content column can center with room. */
			width: 100%;
		}

		/* TOC is hidden below 96rem (1536px) — Flue's 2xl breakpoint — so the
		   content column gets the full main width and centers further right.
		   The TOC is still reachable via the mobile drawer on small screens. */
		.right-sidebar-container {
			display: none;
		}

		/* TOC shows only on ultrawide (≥96rem = 1536px), matching Flue's 2xl
		   breakpoint. Restores Starlight's two-column distribution there. */
		@media (min-width: 96rem) {
			.right-sidebar-container {
				display: block;
				order: 2;
				position: relative;
				width: max(
					var(--sl-sidebar-width),
					calc(
						var(--sl-sidebar-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
					)
				);
			}

			.right-sidebar {
				position: fixed;
				top: 0;
				border-inline-start: 1px solid var(--sl-color-hairline);
				padding-top: var(--sl-nav-height);
				width: 100%;
				height: 100vh;
				overflow-y: auto;
				scrollbar-width: none;
			}

			:global([data-has-sidebar][data-has-toc]) .main-pane {
				--sl-content-margin-inline: auto 0;

				order: 1;
				width: min(
					calc(100% - var(--sl-sidebar-width)),
					calc(
						var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
					)
				);
			}
		}
	}
</style>

	}
</style>
