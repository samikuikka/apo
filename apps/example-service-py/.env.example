# --- LLM provider (OpenRouter via the OpenAI-compatible API) ---
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# --- apo tracing (OpenTelemetry / OTLP) ---
# Backend OTLP traces endpoint. Tracing is enabled by importing app.otel at
# startup; to disable, comment out the setup_otel() call in app/main.py.
APO_OTLP_ENDPOINT=http://localhost:8000/api/public/otel/v1/traces
# Project ID (NOT the name) — find via `apo project list`.
# Sent as service.namespace on the OTLP resource; the backend maps it to project.
APO_PROJECT=
# Auth: required whenever the backend has AUTH_SECRET set (the common case,
# including this repo's default dev config). Mint a key pair in the dashboard.
APO_PUBLIC_KEY=pk-apo-...
APO_SECRET_KEY=sk-apo-...
# Service name shown as the OTLP resource attribute.
APO_SERVICE_NAME=example-service-py

# --- OpenAI GenAI instrumentation config (REQUIRED for content capture) ---
# Use the experimental semantic conventions so prompt/completion content is
# emitted as span attributes (gen_ai.input.messages / gen_ai.output.messages).
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
# Capture the actual prompt + completion text into spans (not just token counts).
# Values: span_only | event_only | span_and_event. span_only is what the apo
# backend's OTLP traces endpoint can read.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=span_only
