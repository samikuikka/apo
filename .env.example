# apo self-hosted alpha — environment template
#
# Copy to .env and fill in real values before running:
#   cp .env.example .env
#   docker compose up -d --build
#
# All values below are REQUIRED for a production deploy unless marked optional.

# --- Required ---

# JWT signing secret shared between frontend and backend.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# --- Optional: database ---
#
# By default the stack uses SQLite (a single file under the apo_db volume),
# identical to local dev — no extra configuration needed. To run Postgres
# instead, apply docker-compose.postgres.yml and set a password here:
#   docker compose -f docker-compose.yml -f docker-compose.postgres.yml up -d --build
#POSTGRES_PASSWORD=         # openssl rand -hex 16
#POSTGRES_DB=apo

# --- Optional: data size control (SQLite only) ---
#
# Age out traces/runs older than N days (0 = disabled). Recommended: 90.
# A daily background job prunes old data and VACUUMs to reclaim space.
#APO_RETENTION_DAYS=0
# Hard ceiling on the DB file size, in 4 KiB pages (0 = unlimited).
# e.g. 262144 pages ~= 1 GiB. Writes fail once the cap is hit.
#APO_MAX_DB_PAGES=0

# --- Optional: first-user bootstrap ---
#
# When set, the backend creates one admin user on first boot (idempotent —
# no-op once any users exist). Normal onboarding is account creation via
# the dashboard + project invite (Settings → Members).
#INIT_USER_EMAIL=admin@example.com
#INIT_USER_PASSWORD=ChangeMe123
#INIT_USER_NAME=Admin

# --- Optional: LLM provider ---
#
# Required only for running real agent tasks (the demo workspace and
# structural tests do not need it). When unset, task runs that call an
# LLM will fail with a clear operator-grade error.
#OPENROUTER_API_KEY=sk-or-v1-...
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#AGENT_TASK_OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# --- Optional: external URL ---
#
# Set to your public HTTPS URL when behind a reverse proxy.
#NEXTAUTH_URL=https://optimizer.mycompany.com
